{
  "name": "test-data-generator",
  "version": "0.1.0",
  "description": "Local test data generator (Electron + Vue3 + SQLite)",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "rebuild:native": "echo \"使用 sql.js，无需原生编译\"",
    "electron:install": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ HTTP_PROXY=http://127.0.0.1:7897 HTTPS_PROXY=http://127.0.0.1:7897 node ./node_modules/electron/install.js",
    "postinstall": "npm run electron:install"
  },
  "dependencies": {
    "element-plus": "^2.9.4",
    "lodash-unified": "^1.0.3",
    "openai": "^4.77.0",
    "sql.js": "^1.12.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vue-tsc": "^2.2.0"
  },
  "build": {
    "appId": "com.testdata.generator",
    "productName": "Test Data Generator",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "win": {
      "target": "nsis"
    }
  }
}
